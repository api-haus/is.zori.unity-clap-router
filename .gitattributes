# Native client libraries are gitignored build outputs staged into Plugins/ (AGENTS.md law 12);
# only the .meta platform-import files are tracked, so no *.so/*.dll/*.dylib LFS rule here.

*.cs text eol=lf
*.meta text eol=lf
*.asmdef text eol=lf
*.json text eol=lf

*.png filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.asset filter=lfs diff=lfs merge=lfs -text
